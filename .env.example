# Pick a provider: huggingface | openrouter | dashscope | local
VLM_PROVIDER=huggingface

# HuggingFace local (downloads weights on first run, ~8 GB for 4B)
# Sizes: Qwen/Qwen3-VL-2B-Instruct, Qwen/Qwen3-VL-4B-Instruct, Qwen/Qwen3-VL-8B-Instruct
HF_MODEL=Qwen/Qwen3-VL-4B-Instruct
HF_MAX_IMAGE_EDGE=1280

# --- Remote alternatives (only used if VLM_PROVIDER set to one of these) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-vl-4b-instruct

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3-vl-plus

LOCAL_VLM_BASE_URL=http://localhost:8000/v1
LOCAL_VLM_MODEL=Qwen/Qwen3-VL-4B-Instruct
LOCAL_VLM_API_KEY=EMPTY
